# Frontend
NEXT_PUBLIC_APP_NAME="00o.uz"
NEXT_PUBLIC_APP_URL="https://00o.uz"
NEXT_PUBLIC_API_URL="http://localhost:8000"
NEXT_PUBLIC_WS_URL="ws://localhost:8000"

# i18n
NEXT_PUBLIC_DEFAULT_LOCALE="uz"
NEXT_PUBLIC_SUPPORTED_LOCALES="uz,ru,en"

# AI (GroqCloud)
NEXT_PUBLIC_GROQ_API_URL="https://api.groq.com/openai/v1"
GROQ_API_KEY="gsk_your_api_key_here"
GROQ_DEFAULT_MODEL="llama-3.3-70b-versatile"

# Telegram Bot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="00o_uz_bot"

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Payment
CLICK_MERCHANT_ID="your_click_id"
CLICK_SECRET_KEY="your_click_secret"
PAYME_MERCHANT_ID="your_payme_id"
PAYME_SECRET_KEY="your_payme_secret"
UZUM_MERCHANT_ID="your_uzum_id"
UZUM_SECRET_KEY="your_uzum_secret"
